__pycache__/
*.pyc
*.pyo
*.pyd

# ── Sistema operacional ──
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ──
.vscode/
.idea/
*.swp
*.swo

# ── Python virtual env (legado Streamlit, não mais usado) ──
.venv/

